# ============================================================
# Groundpath — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in the real values.
# NEVER commit .env — it is listed in .gitignore.
# ============================================================

# ------------------------------------------------------------
# Frontend (Vite) — must be prefixed VITE_ to reach the browser
# ------------------------------------------------------------

# Supabase project URL (find in Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Supabase project ID (used for deeplinks)
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Google Analytics measurement ID (optional, e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Halaxy booking embed URL
VITE_HALAXY_EMBED_URL=https://www.halaxy.com/profile/groundpath/location/your_location_id

# ------------------------------------------------------------
# Supabase Edge Functions — set in Supabase dashboard:
#   Project → Settings → Edge Functions → Secrets
# These values are NEVER exposed to the browser.
# ------------------------------------------------------------

# Supabase service role key (server-side only — keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Supabase URL (same as VITE_SUPABASE_URL but used server-side)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon key for edge function auth checks
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Lovable AI API key (used by ai-assistant and client-ai-assistant functions)
LOVABLE_API_KEY=your_lovable_api_key_here

# OpenAI API key (fallback or alternative AI provider)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Resend API key (used by send-email, send-newsletter, weekly-newsletter functions)
RESEND_API_KEY=re_your_resend_api_key_here
